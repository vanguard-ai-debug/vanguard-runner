# K8s Secrets 配置模板
# 使用说明：
# 1. 复制此文件为 secrets.yaml
# 2. 替换下面的密码为实际密码（base64 编码）
# 3. 不要提交 secrets.yaml 到 Git

apiVersion: v1
kind: Secret
metadata:
  name: spotter-runner-secrets
  namespace: default
type: Opaque
data:
  # 数据库密码（base64 编码）
  # 生成方式: echo -n "your-password" | base64
  db-password: <请替换为实际密码的base64编码>
  
  # Redis 密码（如果有的话）
  # redis-password: <请替换为实际密码的base64编码>

# 示例：
# 如果数据库密码是 "mypassword123"
# 执行: echo -n "mypassword123" | base64
# 得到: bXlwYXNzd29yZDEyMw==
# 然后替换上面的 <请替换为实际密码的base64编码>
