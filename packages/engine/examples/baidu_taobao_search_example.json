{
  "nodes": [
    {
      "id": "launch_browser",
      "type": "browser_launch",
      "data": {
        "config": {
          "operation": "launch",
          "browser_type": "chromium",
          "headless": false
        }
      }
    },
    {
      "id": "navigate_to_baidu",
      "type": "ui_navigation",
      "data": {
        "config": {
          "operation": "navigate",
          "url": "https://www.baidu.com",
          "context_id": "baidu",
          "wait_until": "networkidle",
          "timeout": 60000
        }
      }
    },
    {
      "id": "wait_for_baidu_load",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_network",
          "timeout": 30000
        }
      }
    },
    {
      "id": "wait_for_search_input",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_element",
          "selector": "textbox",
          "selector_type": "role",
          "state": "visible",
          "timeout": 30000
        }
      }
    },
    {
      "id": "input_search_keyword",
      "type": "ui_element",
      "data": {
        "config": {
          "operation": "input",
          "selector": "textbox",
          "selector_type": "role",
          "value": "Agent",
          "timeout": 30000,
          "wait_for_visible": true
        }
      }
    },
    {
      "id": "click_baidu_search_button",
      "type": "ui_element",
      "data": {
        "config": {
          "operation": "click",
          "selector": "button",
          "selector_type": "role",
          "timeout": 30000
        }
      }
    },
    {
      "id": "wait_for_baidu_results",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_element",
          "selector": "#content_left",
          "selector_type": "css",
          "state": "visible",
          "timeout": 15000
        }
      }
    },
    {
      "id": "switch_to_taobao",
      "type": "browser_launch",
      "data": {
        "config": {
          "operation": "switch_context",
          "context_id": "taobao"
        }
      }
    },
    {
      "id": "navigate_to_taobao",
      "type": "ui_navigation",
      "data": {
        "config": {
          "operation": "navigate",
          "url": "https://www.taobao.com",
          "context_id": "taobao",
          "wait_until": "networkidle",
          "timeout": 60000
        }
      }
    },
    {
      "id": "wait_for_taobao_load",
      "type": "ui_navigation",
      "data": {
        "config": {
          "operation": "wait_for_load",
          "wait_until": "networkidle",
          "timeout": 30000
        }
      }
    },
    {
      "id": "wait_for_taobao_searchbox",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_element",
          "selector": "#q",
          "selector_type": "css",
          "state": "visible",
          "timeout": 30000
        }
      }
    },
    {
      "id": "input_taobao_search",
      "type": "ui_element",
      "data": {
        "config": {
          "operation": "input",
          "selector": "#q",
          "selector_type": "css",
          "value": "衣服",
          "timeout": 30000,
          "wait_for_visible": true
        }
      }
    },
    {
      "id": "click_taobao_search_button",
      "type": "ui_element",
      "data": {
        "config": {
          "operation": "click",
          "selector": ".btn-search",
          "selector_type": "css",
          "timeout": 30000
        }
      }
    },
    {
      "id": "wait_for_taobao_results",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_element",
          "selector": ".items",
          "selector_type": "css",
          "state": "visible",
          "timeout": 15000
        }
      }
    },
    {
      "id": "switch_back_to_baidu",
      "type": "browser_launch",
      "data": {
        "config": {
          "operation": "switch_context",
          "context_id": "baidu"
        }
      }
    },
    {
      "id": "capture_baidu_screenshot",
      "type": "screenshot",
      "data": {
        "config": {
          "operation": "full_page_screenshot",
          "page_id": "default",
          "path": "screenshots/baidu_agent_search.png",
          "full_page": true,
          "quality": 90
        }
      }
    },
    {
      "id": "get_baidu_search_count",
      "type": "ui_element",
      "data": {
        "config": {
          "operation": "get_text",
          "selector": ".nums",
          "selector_type": "css",
          "timeout": 10000
        }
      }
    }
  ],
  "edges": [
    {"source": "launch_browser", "target": "navigate_to_baidu"},
    {"source": "navigate_to_baidu", "target": "wait_for_baidu_load"},
    {"source": "wait_for_baidu_load", "target": "wait_for_search_input"},
    {"source": "wait_for_search_input", "target": "input_search_keyword"},
    {"source": "input_search_keyword", "target": "click_baidu_search_button"},
    {"source": "click_baidu_search_button", "target": "wait_for_baidu_results"},
    {"source": "wait_for_baidu_results", "target": "switch_to_taobao"},
    {"source": "switch_to_taobao", "target": "navigate_to_taobao"},
    {"source": "navigate_to_taobao", "target": "wait_for_taobao_load"},
    {"source": "wait_for_taobao_load", "target": "wait_for_taobao_searchbox"},
    {"source": "wait_for_taobao_searchbox", "target": "input_taobao_search"},
    {"source": "input_taobao_search", "target": "click_taobao_search_button"},
    {"source": "click_taobao_search_button", "target": "wait_for_taobao_results"},
    {"source": "wait_for_taobao_results", "target": "switch_back_to_baidu"},
    {"source": "switch_back_to_baidu", "target": "capture_baidu_screenshot"},
    {"source": "capture_baidu_screenshot", "target": "get_baidu_search_count"}
  ]
}

