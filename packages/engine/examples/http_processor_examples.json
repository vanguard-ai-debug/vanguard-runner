{
  "name": "HTTP 处理器增强功能示例",
  "description": "展示 HTTP 处理器的各种参数处理能力",
  "version": "2.0.0",
  "examples": [
    {
      "name": "示例 1: GET 请求 + 查询参数",
      "description": "使用 params 传递查询参数",
      "node": {
        "id": "search_users",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/users",
            "method": "GET",
            "params": {
              "keyword": "${searchKeyword}",
              "page": 1,
              "size": 20,
              "status": "active"
            },
            "headers": {
              "Authorization": "Bearer ${token}"
            }
          }
        }
      },
      "实际请求": "GET https://api.example.com/users?keyword=test&page=1&size=20&status=active"
    },
    {
      "name": "示例 2: POST 表单提交 (data)",
      "description": "使用 data 提交表单数据 (application/x-www-form-urlencoded)",
      "node": {
        "id": "login",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/login",
            "method": "POST",
            "data": {
              "username": "${username}",
              "password": "${password}",
              "remember": "true"
            }
          }
        }
      },
      "说明": "自动使用 application/x-www-form-urlencoded 编码"
    },
    {
      "name": "示例 3: POST JSON 数据",
      "description": "使用 json 发送 JSON 格式数据",
      "node": {
        "id": "create_user",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/users",
            "method": "POST",
            "json": {
              "name": "${userName}",
              "email": "${userEmail}",
              "age": 25,
              "roles": ["user", "admin"]
            },
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer ${token}"
            }
          }
        }
      },
      "说明": "Content-Type 自动设置为 application/json"
    },
    {
      "name": "示例 4: RESTful API 路径参数",
      "description": "使用 path_params 替换 URL 中的 {参数}",
      "node": {
        "id": "get_user_order",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/users/{userId}/orders/{orderId}",
            "method": "GET",
            "path_params": {
              "userId": "${userId}",
              "orderId": "${orderId}"
            },
            "params": {
              "detail": "true"
            }
          }
        }
      },
      "实际请求": "GET https://api.example.com/users/123/orders/456?detail=true"
    },
    {
      "name": "示例 5: 路径参数 + 查询参数 + JSON Body",
      "description": "组合使用多种参数类型",
      "node": {
        "id": "update_user",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/users/{userId}",
            "method": "PUT",
            "path_params": {
              "userId": "${userId}"
            },
            "params": {
              "notify": "true",
              "source": "web"
            },
            "json": {
              "name": "${newName}",
              "email": "${newEmail}"
            }
          }
        }
      },
      "实际请求": "PUT https://api.example.com/users/123?notify=true&source=web"
    },
    {
      "name": "示例 6: 发送原始 Body (XML)",
      "description": "使用 body 发送原始字符串数据",
      "node": {
        "id": "send_xml",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/webhook",
            "method": "POST",
            "body": "<xml><user><name>${userName}</name><email>${userEmail}</email></user></xml>",
            "headers": {
              "Content-Type": "application/xml"
            }
          }
        }
      },
      "说明": "适用于 XML、纯文本等非 JSON/表单格式"
    },
    {
      "name": "示例 7: 文件上传",
      "description": "使用 files 上传文件",
      "node": {
        "id": "upload_file",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/upload",
            "method": "POST",
            "files": {
              "file": "/path/to/avatar.jpg"
            },
            "data": {
              "userId": "${userId}",
              "description": "用户头像"
            }
          }
        }
      },
      "说明": "自动使用 multipart/form-data，可以同时附带表单数据"
    },
    {
      "name": "示例 8: 无参数 GET 请求",
      "description": "最简单的 GET 请求",
      "node": {
        "id": "health_check",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/health",
            "method": "GET"
          }
        }
      },
      "说明": "不需要任何参数，只需要 URL 和 method"
    },
    {
      "name": "示例 9: DELETE 请求",
      "description": "删除资源",
      "node": {
        "id": "delete_user",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/users/{userId}",
            "method": "DELETE",
            "path_params": {
              "userId": "${userId}"
            },
            "headers": {
              "Authorization": "Bearer ${token}"
            }
          }
        }
      },
      "实际请求": "DELETE https://api.example.com/users/123"
    },
    {
      "name": "示例 10: 自定义超时和 SSL",
      "description": "配置高级选项",
      "node": {
        "id": "slow_api",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://slow-api.example.com/data",
            "method": "GET",
            "timeout": 60,
            "verify_ssl": false,
            "allow_redirects": true
          }
        }
      },
      "说明": "适用于慢速API或内网环境"
    },
    {
      "name": "示例 11: 批量查询用户（结合循环）",
      "description": "在循环中使用 HTTP 请求",
      "workflow": {
        "nodes": [
          {
            "id": "batch_query",
            "type": "loop",
            "data": {
              "config": {
                "loop_type": "foreach_loop",
                "items": "${userIds}",
                "item_variable": "userId",
                "delay": 0.1,
                "sub_nodes": [
                  {
                    "type": "http_request",
                    "data": {
                      "config": {
                        "url": "https://api.example.com/users/{userId}",
                        "method": "GET",
                        "path_params": {
                          "userId": "${userId}"
                        },
                        "params": {
                          "detail": "true"
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        ]
      },
      "说明": "遍历用户 ID 列表，逐个查询用户信息"
    },
    {
      "name": "示例 12: 复杂的 POST 请求",
      "description": "包含多层嵌套的 JSON 数据",
      "node": {
        "id": "create_order",
        "type": "http_request",
        "data": {
          "config": {
            "url": "https://api.example.com/orders",
            "method": "POST",
            "json": {
              "userId": "${userId}",
              "orderType": "${orderType}",
              "items": [
                {
                  "productId": "${product1Id}",
                  "quantity": 2,
                  "price": 99.99
                },
                {
                  "productId": "${product2Id}",
                  "quantity": 1,
                  "price": 199.99
                }
              ],
              "shipping": {
                "address": "${shippingAddress}",
                "method": "express"
              },
              "payment": {
                "method": "wechat",
                "amount": 399.97
              }
            }
          }
        }
      },
      "说明": "支持复杂的嵌套 JSON 结构，自动变量替换"
    }
  ],
  "参数优先级说明": {
    "Body 数据优先级": "files > json > data > body",
    "说明": [
      "1. files: 文件上传，使用 multipart/form-data",
      "2. json: JSON 数据，使用 application/json",
      "3. data: 表单数据，使用 application/x-www-form-urlencoded",
      "4. body: 原始数据，使用自定义 Content-Type"
    ]
  },
  "向后兼容性": {
    "旧配置": {
      "url": "...",
      "method": "POST",
      "body": {
        "key": "value"
      }
    },
    "说明": "旧版本的 body (dict) 会自动转换为 json，完全兼容"
  }
}

