{
  "name": "RocketMQ 消息发送工作流示例",
  "description": "演示如何使用 RocketMQ 处理器发送消息",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "rocketmq_send_1",
      "type": "rocketmq",
      "name": "发送订单消息",
      "data": {
        "config": {
          "topic": "order_topic",
          "message_body": "Order created successfully",
          "environment": "dev",
          "site_tenant": "US_AMZ",
          "tag": "order_created",
          "key": "order_12345",
          "timeout": 30,
          "output_variable": "order_mq_result"
        }
      },
      "position": {
        "x": 100,
        "y": 100
      }
    },
    {
      "id": "log_result_1",
      "type": "log_message",
      "name": "记录订单消息结果",
      "data": {
        "config": {
          "message": "订单消息发送结果: ${order_mq_result}",
          "level": "info"
        }
      },
      "position": {
        "x": 100,
        "y": 200
      }
    },
    {
      "id": "rocketmq_send_2",
      "type": "rocketmq",
      "name": "发送用户消息",
      "data": {
        "config": {
          "topic": "user_topic",
          "message_body": "User profile updated",
          "environment": "dev",
          "site_tenant": "US_AMZ",
          "tag": "user_updated",
          "key": "user_67890",
          "timeout": 30,
          "output_variable": "user_mq_result"
        }
      },
      "position": {
        "x": 300,
        "y": 100
      }
    },
    {
      "id": "log_result_2",
      "type": "log_message",
      "name": "记录用户消息结果",
      "data": {
        "config": {
          "message": "用户消息发送结果: ${user_mq_result}",
          "level": "info"
        }
      },
      "position": {
        "x": 300,
        "y": 200
      }
    },
    {
      "id": "rocketmq_send_with_variables",
      "type": "rocketmq",
      "name": "带变量的消息发送",
      "data": {
        "config": {
          "topic": "${topic_name}",
          "message_body": "${message_content}",
          "environment": "${env}",
          "site_tenant": "${tenant}",
          "tag": "${message_tag}",
          "key": "${message_key}",
          "timeout": 30,
          "custom_headers": {
            "Authorization": "Bearer ${auth_token}",
            "X-Request-ID": "${request_id}"
          },
          "output_variable": "variable_mq_result"
        }
      },
      "position": {
        "x": 500,
        "y": 100
      }
    },
    {
      "id": "log_variable_result",
      "type": "log_message",
      "name": "记录变量消息结果",
      "data": {
        "config": {
          "message": "带变量的消息发送结果: ${variable_mq_result}",
          "level": "info"
        }
      },
      "position": {
        "x": 500,
        "y": 200
      }
    },
    {
      "id": "rocketmq_json_message",
      "type": "rocketmq",
      "name": "发送 JSON 消息",
      "data": {
        "config": {
          "topic": "data_topic",
          "message_body": {
            "event_type": "order_created",
            "order_id": "order_99999",
            "user_id": "user_88888",
            "amount": 199.99,
            "timestamp": "${timestamp}"
          },
          "environment": "dev",
          "site_tenant": "US_AMZ",
          "tag": "data_event",
          "key": "order_99999",
          "timeout": 30,
          "output_variable": "json_mq_result"
        }
      },
      "position": {
        "x": 700,
        "y": 100
      }
    },
    {
      "id": "log_json_result",
      "type": "log_message",
      "name": "记录 JSON 消息结果",
      "data": {
        "config": {
          "message": "JSON 消息发送结果: ${json_mq_result}",
          "level": "info"
        }
      },
      "position": {
        "x": 700,
        "y": 200
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "rocketmq_send_1",
      "target": "log_result_1"
    },
    {
      "id": "e2",
      "source": "rocketmq_send_2",
      "target": "log_result_2"
    },
    {
      "id": "e3",
      "source": "rocketmq_send_with_variables",
      "target": "log_variable_result"
    },
    {
      "id": "e4",
      "source": "rocketmq_json_message",
      "target": "log_json_result"
    }
  ],
  "variables": {
    "topic_name": "custom_topic",
    "message_content": "Custom message content",
    "env": "dev",
    "tenant": "US_AMZ",
    "message_tag": "custom_tag",
    "message_key": "custom_key",
    "auth_token": "bearer_token_123",
    "request_id": "req_123456789",
    "timestamp": "2025-01-15T10:30:00Z"
  }
}
