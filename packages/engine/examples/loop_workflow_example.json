{
  "name": "循环控制器工作流示例",
  "description": "演示三种循环控制器的使用方法",
  "version": "1.0.0",
  "variables": {
    "loop_count": 3,
    "delay_time": 0.1,
    "test_items": ["订单1", "订单2", "订单3", "订单4"],
    "max_attempts": 5
  },
  "nodes": [
    {
      "id": "count_loop_example",
      "type": "loop",
      "name": "次数循环示例",
      "data": {
        "config": {
          "loop_type": "count_loop",
          "count": "${loop_count}",
          "delay": "${delay_time}",
          "sub_nodes": [
            {
              "id": "log_iteration",
              "type": "log_message",
              "data": {
                "config": {
                  "message": "执行第 ${loop_index + 1} 次循环",
                  "level": "info"
                }
              }
            },
            {
              "id": "process_data",
              "type": "variable_extractor",
              "data": {
                "config": {
                  "variable": "iteration_data",
                  "value": "处理数据 ${loop_index + 1}",
                  "output_variable": "processed_data_${loop_index}"
                }
              }
            }
          ],
          "output_variable": "count_loop_result"
        }
      },
      "position": {
        "x": 100,
        "y": 100
      }
    },
    {
      "id": "while_loop_example",
      "type": "loop",
      "name": "While 循环示例",
      "data": {
        "config": {
          "loop_type": "while_loop",
          "condition": "iteration < 3",
          "max_iterations": "${max_attempts}",
          "delay": "${delay_time}",
          "sub_nodes": [
            {
              "id": "check_condition",
              "type": "log_message",
              "data": {
                "config": {
                  "message": "While 循环第 ${loop_index + 1} 次，条件: ${condition}",
                  "level": "info"
                }
              }
            },
            {
              "id": "simulate_work",
              "type": "sleep",
              "data": {
                "config": {
                  "duration": 0.05
                }
              }
            }
          ],
          "output_variable": "while_loop_result"
        }
      },
      "position": {
        "x": 300,
        "y": 100
      }
    },
    {
      "id": "foreach_loop_example",
      "type": "loop",
      "name": "ForEach 循环示例",
      "data": {
        "config": {
          "loop_type": "foreach_loop",
          "items": "${test_items}",
          "item_variable": "current_item",
          "index_variable": "item_index",
          "delay": "${delay_time}",
          "sub_nodes": [
            {
              "id": "process_item",
              "type": "log_message",
              "data": {
                "config": {
                  "message": "处理项目: ${current_item} (索引: ${item_index})",
                  "level": "info"
                }
              }
            },
            {
              "id": "extract_item_data",
              "type": "variable_extractor",
              "data": {
                "config": {
                  "variable": "item_result",
                  "value": "${current_item}_已处理",
                  "output_variable": "item_${item_index}_result"
                }
              }
            }
          ],
          "output_variable": "foreach_loop_result"
        }
      },
      "position": {
        "x": 500,
        "y": 100
      }
    },
    {
      "id": "nested_loop_example",
      "type": "loop",
      "name": "嵌套循环示例",
      "data": {
        "config": {
          "loop_type": "count_loop",
          "count": 2,
          "delay": 0.1,
          "sub_nodes": [
            {
              "id": "outer_log",
              "type": "log_message",
              "data": {
                "config": {
                  "message": "外层循环第 ${loop_index + 1} 次",
                  "level": "info"
                }
              }
            },
            {
              "id": "inner_loop",
              "type": "loop",
              "data": {
                "config": {
                  "loop_type": "foreach_loop",
                  "items": ["子项目A", "子项目B"],
                  "item_variable": "inner_item",
                  "delay": 0.05,
                  "sub_nodes": [
                    {
                      "id": "inner_log",
                      "type": "log_message",
                      "data": {
                        "config": {
                          "message": "  内层循环: ${inner_item}",
                          "level": "debug"
                        }
                      }
                    }
                  ]
                }
              }
            }
          ],
          "output_variable": "nested_loop_result"
        }
      },
      "position": {
        "x": 100,
        "y": 300
      }
    },
    {
      "id": "conditional_loop_example",
      "type": "loop",
      "name": "条件循环示例",
      "data": {
        "config": {
          "loop_type": "while_loop",
          "condition": "iteration < 2",
          "max_iterations": 5,
          "delay": 0.1,
          "sub_nodes": [
            {
              "id": "check_retry",
              "type": "condition",
              "data": {
                "config": {
                  "condition": "${loop_index} < 2",
                  "true_nodes": [
                    {
                      "id": "success_log",
                      "type": "log_message",
                      "data": {
                        "config": {
                          "message": "条件满足，继续执行",
                          "level": "info"
                        }
                      }
                    }
                  ],
                  "false_nodes": [
                    {
                      "id": "break_log",
                      "type": "log_message",
                      "data": {
                        "config": {
                          "message": "条件不满足，准备退出循环",
                          "level": "warn"
                        }
                      }
                    }
                  ]
                }
              }
            }
          ],
          "output_variable": "conditional_loop_result"
        }
      },
      "position": {
        "x": 300,
        "y": 300
      }
    },
    {
      "id": "final_summary",
      "type": "log_message",
      "name": "最终总结",
      "data": {
        "config": {
          "message": "所有循环执行完成 - 次数循环: ${count_loop_result}, While循环: ${while_loop_result}, ForEach循环: ${foreach_loop_result}",
          "level": "info"
        }
      },
      "position": {
        "x": 500,
        "y": 300
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "count_loop_example",
      "target": "while_loop_example"
    },
    {
      "id": "e2",
      "source": "while_loop_example",
      "target": "foreach_loop_example"
    },
    {
      "id": "e3",
      "source": "foreach_loop_example",
      "target": "nested_loop_example"
    },
    {
      "id": "e4",
      "source": "nested_loop_example",
      "target": "conditional_loop_example"
    },
    {
      "id": "e5",
      "source": "conditional_loop_example",
      "target": "final_summary"
    }
  ]
}
