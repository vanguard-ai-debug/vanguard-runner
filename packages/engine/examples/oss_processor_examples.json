{
  "name": "OSS 处理器使用示例",
  "description": "展示 OSS 对象存储的上传、下载、删除功能",
  "version": "1.0.0",
  "variables": {
    "OSS_ACCESS_KEY": "your-access-key-id",
    "OSS_SECRET_KEY": "your-secret-key",
    "OSS_ENDPOINT": "https://oss-cn-hangzhou.aliyuncs.com",
    "OSS_BUCKET": "my-test-bucket"
  },
  "examples": [
    {
      "name": "示例 1: 上传文件到 OSS",
      "description": "将本地文件上传到 OSS",
      "node": {
        "id": "upload_to_oss",
        "type": "oss",
        "data": {
          "config": {
            "operation": "upload",
            "access_key_id": "${OSS_ACCESS_KEY}",
            "access_key_secret": "${OSS_SECRET_KEY}",
            "endpoint": "${OSS_ENDPOINT}",
            "bucket": "${OSS_BUCKET}",
            "local_path": "/path/to/local/test.txt",
            "oss_path": "documents/test.txt",
            "output_variable": "uploaded_file_path"
          },
          "assertion": {
            "rules": [
              {
                "source": "body.status",
                "operator": "string_equals",
                "target": "success",
                "message": "文件上传失败"
              }
            ]
          },
          "extractions": [
            {
              "var_name": "oss_file_path",
              "source_path": "body.oss_path"
            },
            {
              "var_name": "upload_etag",
              "source_path": "body.etag"
            }
          ]
        }
      },
      "说明": "上传成功后，OSS 路径会保存到 uploaded_file_path 变量"
    },
    {
      "name": "示例 2: 从 OSS 下载文件",
      "description": "从 OSS 下载文件到本地",
      "node": {
        "id": "download_from_oss",
        "type": "oss",
        "data": {
          "config": {
            "operation": "download",
            "access_key_id": "${OSS_ACCESS_KEY}",
            "access_key_secret": "${OSS_SECRET_KEY}",
            "endpoint": "${OSS_ENDPOINT}",
            "bucket": "${OSS_BUCKET}",
            "oss_path": "documents/test.txt",
            "local_path": "/tmp/downloaded_test.txt",
            "output_variable": "downloaded_file_path"
          },
          "assertion": {
            "rules": [
              {
                "source": "body.status",
                "operator": "string_equals",
                "target": "success",
                "message": "文件下载失败"
              },
              {
                "source": "body.file_size",
                "operator": "greater_than",
                "target": 0,
                "message": "下载的文件大小为 0"
              }
            ]
          },
          "extractions": [
            {
              "var_name": "local_file_path",
              "source_path": "body.local_path"
            },
            {
              "var_name": "file_size",
              "source_path": "body.file_size"
            }
          ]
        }
      },
      "说明": "下载成功后，本地路径会保存到 downloaded_file_path 变量"
    },
    {
      "name": "示例 3: 下载后上传（OSS → 本地 → HTTP 上传）",
      "description": "先从 OSS 下载，再通过 HTTP 上传到其他服务",
      "workflow": {
        "nodes": [
          {
            "id": "step1_download",
            "type": "oss",
            "name": "从 OSS 下载文件",
            "data": {
              "config": {
                "operation": "download",
                "access_key_id": "${OSS_ACCESS_KEY}",
                "access_key_secret": "${OSS_SECRET_KEY}",
                "endpoint": "${OSS_ENDPOINT}",
                "bucket": "${OSS_BUCKET}",
                "oss_path": "images/avatar.jpg",
                "local_path": "/tmp/avatar.jpg",
                "output_variable": "avatar_local_path"
              }
            }
          },
          {
            "id": "step2_upload",
            "type": "http_request",
            "name": "通过 HTTP 上传文件",
            "data": {
              "config": {
                "url": "https://api.example.com/upload",
                "method": "POST",
                "files": {
                  "avatar": "${avatar_local_path}"
                },
                "data": {
                  "userId": "${userId}",
                  "description": "用户头像"
                }
              }
            }
          }
        ],
        "edges": [
          {
            "id": "e1",
            "source": "step1_download",
            "target": "step2_upload"
          }
        ]
      },
      "说明": "完整的 OSS 下载 + HTTP 上传流程"
    },
    {
      "name": "示例 4: 上传文件流",
      "description": "直接上传字符串或字节流到 OSS",
      "node": {
        "id": "upload_stream",
        "type": "oss",
        "data": {
          "config": {
            "operation": "upload_stream",
            "access_key_id": "${OSS_ACCESS_KEY}",
            "access_key_secret": "${OSS_SECRET_KEY}",
            "endpoint": "${OSS_ENDPOINT}",
            "bucket": "${OSS_BUCKET}",
            "oss_path": "logs/app-${timestamp}.log",
            "content": "Application log content\nLine 1\nLine 2\nLine 3",
            "output_variable": "log_file_path"
          }
        }
      },
      "说明": "适用于动态生成的内容，无需先保存到本地"
    },
    {
      "name": "示例 5: 删除 OSS 文件",
      "description": "删除 OSS 上的文件",
      "node": {
        "id": "delete_from_oss",
        "type": "oss",
        "data": {
          "config": {
            "operation": "delete",
            "access_key_id": "${OSS_ACCESS_KEY}",
            "access_key_secret": "${OSS_SECRET_KEY}",
            "endpoint": "${OSS_ENDPOINT}",
            "bucket": "${OSS_BUCKET}",
            "oss_path": "temp/old_file.txt"
          },
          "assertion": {
            "rules": [
              {
                "source": "body.status",
                "operator": "string_equals",
                "target": "success",
                "message": "文件删除失败"
              }
            ]
          }
        }
      },
      "说明": "删除成功返回状态码 204"
    },
    {
      "name": "示例 6: 批量操作（循环上传）",
      "description": "使用循环处理器批量上传文件",
      "workflow": {
        "nodes": [
          {
            "id": "batch_upload",
            "type": "loop",
            "data": {
              "config": {
                "loop_type": "foreach_loop",
                "items": [
                  "/path/to/file1.txt",
                  "/path/to/file2.txt",
                  "/path/to/file3.txt"
                ],
                "item_variable": "file_path",
                "index_variable": "file_index",
                "sub_nodes": [
                  {
                    "type": "oss",
                    "data": {
                      "config": {
                        "operation": "upload",
                        "access_key_id": "${OSS_ACCESS_KEY}",
                        "access_key_secret": "${OSS_SECRET_KEY}",
                        "endpoint": "${OSS_ENDPOINT}",
                        "bucket": "${OSS_BUCKET}",
                        "local_path": "${file_path}",
                        "oss_path": "batch_upload/file_${file_index}.txt"
                      }
                    }
                  }
                ]
              }
            }
          }
        ]
      },
      "说明": "循环上传多个文件"
    },
    {
      "name": "示例 7: 测试报告上传",
      "description": "生成测试报告并上传到 OSS",
      "workflow": {
        "nodes": [
          {
            "id": "generate_report",
            "type": "script",
            "name": "生成测试报告",
            "data": {
              "config": {
                "code": "report_content = f'Test Report\\nDate: {datetime.now()}\\nStatus: PASSED'",
                "output_variable": "report_content"
              }
            }
          },
          {
            "id": "upload_report",
            "type": "oss",
            "name": "上传报告到 OSS",
            "data": {
              "config": {
                "operation": "upload_stream",
                "access_key_id": "${OSS_ACCESS_KEY}",
                "access_key_secret": "${OSS_SECRET_KEY}",
                "endpoint": "${OSS_ENDPOINT}",
                "bucket": "${OSS_BUCKET}",
                "oss_path": "reports/test_report_${timestamp}.txt",
                "content": "${report_content}"
              }
            }
          }
        ],
        "edges": [
          {
            "id": "e1",
            "source": "generate_report",
            "target": "upload_report"
          }
        ]
      },
      "说明": "动态生成内容并上传"
    },
    {
      "name": "示例 8: 文件备份流程",
      "description": "下载、处理、重新上传",
      "workflow": {
        "nodes": [
          {
            "id": "download_original",
            "type": "oss",
            "name": "下载原始文件",
            "data": {
              "config": {
                "operation": "download",
                "access_key_id": "${OSS_ACCESS_KEY}",
                "access_key_secret": "${OSS_SECRET_KEY}",
                "endpoint": "${OSS_ENDPOINT}",
                "bucket": "${OSS_BUCKET}",
                "oss_path": "data/original.json",
                "local_path": "/tmp/original.json",
                "output_variable": "original_file"
              }
            }
          },
          {
            "id": "process_file",
            "type": "script",
            "name": "处理文件",
            "data": {
              "config": {
                "code": "# 处理文件逻辑\nprocessed_path = '/tmp/processed.json'",
                "output_variable": "processed_file"
              }
            }
          },
          {
            "id": "upload_backup",
            "type": "oss",
            "name": "上传备份文件",
            "data": {
              "config": {
                "operation": "upload",
                "access_key_id": "${OSS_ACCESS_KEY}",
                "access_key_secret": "${OSS_SECRET_KEY}",
                "endpoint": "${OSS_ENDPOINT}",
                "bucket": "${OSS_BUCKET}",
                "local_path": "${processed_file}",
                "oss_path": "backup/processed_${timestamp}.json"
              }
            }
          }
        ],
        "edges": [
          {
            "id": "e1",
            "source": "download_original",
            "target": "process_file"
          },
          {
            "id": "e2",
            "source": "process_file",
            "target": "upload_backup"
          }
        ]
      },
      "说明": "完整的文件处理和备份流程"
    }
  ],
  "配置说明": {
    "必填字段": {
      "operation": "操作类型: upload, upload_stream, download, delete",
      "access_key_id": "OSS Access Key ID",
      "access_key_secret": "OSS Access Key Secret",
      "endpoint": "OSS Endpoint (如: https://oss-cn-hangzhou.aliyuncs.com)",
      "bucket": "Bucket 名称"
    },
    "操作特定字段": {
      "upload": {
        "local_path": "本地文件路径",
        "oss_path": "OSS 目标路径"
      },
      "upload_stream": {
        "content": "文件内容（字符串或字节）",
        "oss_path": "OSS 目标路径"
      },
      "download": {
        "oss_path": "OSS 文件路径",
        "local_path": "本地保存路径"
      },
      "delete": {
        "oss_path": "要删除的 OSS 文件路径"
      }
    },
    "可选字段": {
      "output_variable": "输出变量名，默认为 oss_upload_path 或 oss_download_path"
    }
  },
  "安装依赖": {
    "命令": "pip install oss2",
    "说明": "需要安装 oss2 库才能使用 OSS 功能"
  }
}

