{
  "name": "OSS 与 HTTP 处理器集成测试",
  "description": "演示如何从 OSS 下载文件，然后通过 HTTP 上传",
  "version": "1.0.0",
  "author": "Aegis Team",
  "created_at": "2025-10-30",
  "variables": {
    "OSS_ACCESS_KEY": "your-access-key-id",
    "OSS_SECRET_KEY": "your-secret-key",
    "OSS_ENDPOINT": "https://oss-cn-hangzhou.aliyuncs.com",
    "OSS_BUCKET": "my-test-bucket",
    "userId": "12345",
    "timestamp": "20251030"
  },
  "workflow": {
    "nodes": [
      {
        "id": "step1_upload_to_oss",
        "type": "oss",
        "name": "1. 上传文件到 OSS",
        "data": {
          "config": {
            "operation": "upload",
            "access_key_id": "${OSS_ACCESS_KEY}",
            "access_key_secret": "${OSS_SECRET_KEY}",
            "endpoint": "${OSS_ENDPOINT}",
            "bucket": "${OSS_BUCKET}",
            "local_path": "/path/to/local/avatar.jpg",
            "oss_path": "images/avatar_${userId}.jpg",
            "output_variable": "uploaded_oss_path"
          },
          "assertion": {
            "rules": [
              {
                "source": "body.status",
                "operator": "string_equals",
                "target": "success",
                "message": "文件上传到 OSS 失败"
              },
              {
                "source": "status_code",
                "operator": "equals",
                "target": 200,
                "message": "OSS 上传状态码不是 200"
              }
            ]
          },
          "extractions": [
            {
              "var_name": "oss_file_path",
              "source_path": "body.oss_path"
            },
            {
              "var_name": "upload_etag",
              "source_path": "body.etag"
            }
          ]
        }
      },
      {
        "id": "step2_download_from_oss",
        "type": "oss",
        "name": "2. 从 OSS 下载文件",
        "data": {
          "config": {
            "operation": "download",
            "access_key_id": "${OSS_ACCESS_KEY}",
            "access_key_secret": "${OSS_SECRET_KEY}",
            "endpoint": "${OSS_ENDPOINT}",
            "bucket": "${OSS_BUCKET}",
            "oss_path": "${oss_file_path}",
            "local_path": "/tmp/downloaded_avatar_${userId}.jpg",
            "output_variable": "downloaded_file_path"
          },
          "assertion": {
            "rules": [
              {
                "source": "body.status",
                "operator": "string_equals",
                "target": "success",
                "message": "从 OSS 下载文件失败"
              },
              {
                "source": "body.file_size",
                "operator": "greater_than",
                "target": 0,
                "message": "下载的文件大小为 0"
              }
            ]
          },
          "extractions": [
            {
              "var_name": "local_file_path",
              "source_path": "body.local_path"
            },
            {
              "var_name": "file_size",
              "source_path": "body.file_size"
            }
          ]
        }
      },
      {
        "id": "step3_upload_via_http",
        "type": "http_request",
        "name": "3. 通过 HTTP 上传文件",
        "data": {
          "config": {
            "url": "https://api.example.com/upload",
            "method": "POST",
            "headers": {
              "Authorization": "Bearer ${access_token}",
              "X-User-Id": "${userId}"
            },
            "files": {
              "avatar": "${downloaded_file_path}"
            },
            "data": {
              "userId": "${userId}",
              "description": "用户头像上传",
              "originalOssPath": "${oss_file_path}",
              "fileSize": "${file_size}"
            }
          },
          "assertion": {
            "rules": [
              {
                "source": "status_code",
                "operator": "equals",
                "target": 200,
                "message": "HTTP 上传失败"
              },
              {
                "source": "body.success",
                "operator": "equals",
                "target": true,
                "message": "上传接口返回失败"
              }
            ]
          },
          "extractions": [
            {
              "var_name": "uploaded_url",
              "source_path": "body.url"
            },
            {
              "var_name": "file_id",
              "source_path": "body.fileId"
            }
          ]
        }
      },
      {
        "id": "step4_verify",
        "type": "log_message",
        "name": "4. 验证结果",
        "data": {
          "config": {
            "message": "文件上传完成！OSS路径: ${oss_file_path}, 下载到: ${local_file_path}, 上传到: ${uploaded_url}, 文件ID: ${file_id}",
            "level": "info"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "step1_upload_to_oss",
        "target": "step2_download_from_oss",
        "description": "上传成功后下载"
      },
      {
        "id": "e2",
        "source": "step2_download_from_oss",
        "target": "step3_upload_via_http",
        "description": "下载成功后通过 HTTP 上传"
      },
      {
        "id": "e3",
        "source": "step3_upload_via_http",
        "target": "step4_verify",
        "description": "上传成功后验证"
      }
    ]
  },
  "测试说明": {
    "流程": [
      "1. 将本地文件上传到阿里云 OSS",
      "2. 从 OSS 下载刚刚上传的文件到本地临时目录",
      "3. 通过 HTTP 接口将下载的文件上传到其他服务",
      "4. 验证整个流程完成"
    ],
    "关键点": [
      "OSS 上传后，路径保存在变量 oss_file_path",
      "OSS 下载后，本地路径保存在变量 downloaded_file_path",
      "HTTP 处理器使用 ${downloaded_file_path} 读取文件",
      "支持文件中转和多平台上传"
    ],
    "应用场景": [
      "多云存储同步",
      "文件备份和迁移",
      "图片/视频处理流程",
      "测试报告分发",
      "跨平台文件共享"
    ]
  },
  "环境变量配置": {
    "OSS_ACCESS_KEY": "在环境变量或工作流变量中配置",
    "OSS_SECRET_KEY": "在环境变量或工作流变量中配置",
    "OSS_ENDPOINT": "阿里云 OSS Endpoint",
    "OSS_BUCKET": "OSS Bucket 名称",
    "access_token": "HTTP 接口的访问令牌"
  }
}

