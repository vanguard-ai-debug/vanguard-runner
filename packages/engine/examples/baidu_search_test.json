{
  "nodes": [
    {
      "id": "launch_browser",
      "type": "browser_launch",
      "data": {
        "config": {
          "operation": "launch",
          "browser_type": "chromium",
          "headless": false
        }
      }
    },
    {
      "id": "navigate_to_baidu",
      "type": "ui_navigation",
      "data": {
        "config": {
          "operation": "navigate",
          "url": "https://www.baidu.com"
        }
      }
    },
    {
      "id": "wait_for_page_load",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_network",
          "timeout": 10000
        }
      }
    },
    {
      "id": "wait_for_search_input",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_element",
          "selector": "textbox",
          "selector_type": "role",
          "state": "visible",
          "timeout": 10000
        }
      }
    },
    {
      "id": "input_search_keyword",
      "type": "ui_element",
      "data": {
        "config": {
          "operation": "input",
          "selector": "textbox",
          "selector_type": "role",
          "value": "人工智能",
          "timeout": 30000,
          "wait_for_visible": true
        }
      }
    },
    {
      "id": "wait_for_search_button",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_element",
          "selector": "button",
          "selector_type": "role",
          "state": "visible",
          "timeout": 10000
        }
      }
    },
    {
      "id": "click_search_button",
      "type": "ui_element",
      "data": {
        "config": {
          "operation": "click",
          "selector": "button",
          "selector_type": "role",
          "timeout": 30000
        }
      }
    },
    {
      "id": "wait_for_search_results",
      "type": "smart_wait",
      "data": {
        "config": {
          "operation": "wait_for_element",
          "selector": "#content_left",
          "state": "visible",
          "timeout": 10000
        }
      }
    },
    {
      "id": "verify_search_results",
      "type": "ui_element",
      "data": {
        "config": {
          "operation": "get_text",
          "selector": "#content_left .result",
          "timeout": 5000
        }
      }
    },
    {
      "id": "capture_screenshot",
      "type": "observability",
      "data": {
        "config": {
          "operation": "capture_diagnostic",
          "node_id": "search_results",
          "capture_screenshot": true,
          "capture_dom": false,
          "capture_console": true,
          "capture_network": false,
          "capture_performance": false
        }
      }
    }
  ],
  "edges": [
    {"source": "launch_browser", "target": "navigate_to_baidu"},
    {"source": "navigate_to_baidu", "target": "wait_for_page_load"},
    {"source": "wait_for_page_load", "target": "wait_for_search_input"},
    {"source": "wait_for_search_input", "target": "input_search_keyword"},
    {"source": "input_search_keyword", "target": "wait_for_search_button"},
    {"source": "wait_for_search_button", "target": "click_search_button"},
    {"source": "click_search_button", "target": "wait_for_search_results"},
    {"source": "wait_for_search_results", "target": "verify_search_results"},
    {"source": "verify_search_results", "target": "capture_screenshot"}
  ]
}

